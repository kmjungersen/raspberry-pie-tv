#!/bin/sh
# REPO_DIR is injected here by scripts/install.sh.

# Keep the screen on forever.
xset s off
xset s noblank
xset -dpms

# Hide the mouse cursor.
unclutter -idle 0 -root &

# Pull the latest deck before launching the kiosk so a fresh boot
# shows current content. update.sh is bounded internally and exits 0
# on any failure, so an offline boot just falls through quickly.
"$REPO_DIR/scripts/update.sh" >/tmp/slideshow-update.log 2>&1 || true

# Launch the kiosk (wraps Chromium in a restart loop).
exec "$REPO_DIR/scripts/run-kiosk.sh"
